---
import type { PlannerEntry } from '../lib/data';

interface Props {
  planner: PlannerEntry;
}

const { planner } = Astro.props;

const subjectColors: Record<string, string> = {
  'Mathematics': 'bg-blue-50 text-blue-700 border-blue-200',
  'English': 'bg-purple-50 text-purple-700 border-purple-200',
  'Science': 'bg-green-50 text-green-700 border-green-200',
  'History': 'bg-amber-50 text-amber-700 border-amber-200',
  'Geography': 'bg-teal-50 text-teal-700 border-teal-200',
  'Computing': 'bg-indigo-50 text-indigo-700 border-indigo-200',
  'Art and Design': 'bg-pink-50 text-pink-700 border-pink-200',
  'Music': 'bg-violet-50 text-violet-700 border-violet-200',
  'Design and Technology': 'bg-orange-50 text-orange-700 border-orange-200',
  'General': 'bg-gray-50 text-gray-700 border-gray-200',
};

const badgeClass = subjectColors[planner.subject] || 'bg-gray-50 text-gray-700 border-gray-200';

const subjectBorders: Record<string, string> = {
  'Mathematics': 'border-l-blue-500',
  'English': 'border-l-purple-500',
  'Science': 'border-l-green-500',
  'History': 'border-l-amber-500',
  'Geography': 'border-l-teal-500',
  'Computing': 'border-l-indigo-500',
  'Art and Design': 'border-l-pink-500',
  'Music': 'border-l-violet-500',
  'Design and Technology': 'border-l-orange-500',
  'General': 'border-l-gray-400',
};

const borderClass = subjectBorders[planner.subject] || 'border-l-gray-400';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Coverage ratio as percentage for indicator
const coverageParts = planner.coverage ? planner.coverage.split('/') : [];
const coveragePct = coverageParts.length === 2
  ? Math.round((parseInt(coverageParts[0]) / parseInt(coverageParts[1])) * 100)
  : 0;
---

<div
  class:list={['bg-white rounded-lg border border-gray-200 border-l-4 p-4 flex flex-col', borderClass]}
  data-subject={planner.subject}
  data-ks={planner.key_stage}
  data-status={planner.status}
  data-years={planner.year_groups.join(',')}
>
  <a
    href={`${base}/planners/${planner.folder}/${planner.slug}`}
    class="block hover:text-blue-600 transition-colors"
  >
    <h3 class="font-semibold text-gray-900 text-sm leading-snug">{planner.title}</h3>
  </a>

  <div class="flex flex-wrap items-center gap-1.5 mt-2">
    <span class:list={['text-xs px-2 py-0.5 rounded border font-medium', badgeClass]}>
      {planner.subject}
    </span>
    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">
      {planner.key_stage}
    </span>
    {planner.year_groups.map(yg => (
      <span class="text-xs bg-gray-50 text-gray-500 px-1.5 py-0.5 rounded">{yg}</span>
    ))}
  </div>

  <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
    {planner.duration && <span>{planner.duration}</span>}
    {planner.study_type && (
      <>
        <span class="text-gray-300">|</span>
        <span>{planner.study_type}</span>
      </>
    )}
    {planner.status && (
      <>
        <span class="text-gray-300">|</span>
        <span class:list={[planner.status === 'Mandatory' ? 'text-blue-600 font-medium' : '']}>
          {planner.status}
        </span>
      </>
    )}
  </div>

  {planner.coverage && (
    <div class="mt-3">
      <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
        <span>Coverage</span>
        <span>{planner.coverage}</span>
      </div>
      <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div
          class="h-full bg-emerald-500 rounded-full"
          style={`width: ${coveragePct}%`}
        />
      </div>
    </div>
  )}

  <div class="mt-auto pt-3 flex items-center gap-2">
    <a
      href={`${base}/planners/${planner.folder}/${planner.slug}`}
      class="text-xs text-blue-600 hover:text-blue-800 font-medium"
    >
      View planner &rarr;
    </a>
    <a
      href={`${base}/planners/${planner.folder}/${planner.slug}.md`}
      download
      class="ml-auto text-xs text-gray-400 hover:text-gray-600"
      title="Download Markdown"
    >
      <svg class="w-4 h-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
      </svg>
    </a>
  </div>
</div>
