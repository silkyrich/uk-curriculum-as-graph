---
interface Props {
  levels: Array<{
    label: string;
    level_number: number;
    description: string;
    example_task?: string;
    example_response?: string;
    common_errors?: string;
  }>;
  compact?: boolean;
}

const { levels, compact = false } = Astro.props;

const levelColors: Record<string, string> = {
  entry: 'bg-green-100 text-green-800 border-green-200',
  developing: 'bg-yellow-100 text-yellow-800 border-yellow-200',
  expected: 'bg-blue-100 text-blue-800 border-blue-200',
  greater_depth: 'bg-purple-100 text-purple-800 border-purple-200',
  emerging: 'bg-green-100 text-green-800 border-green-200',
  secure: 'bg-blue-100 text-blue-800 border-blue-200',
  mastery: 'bg-purple-100 text-purple-800 border-purple-200',
};

function labelDisplay(label: string): string {
  return label.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<div class:list={['grid gap-2', compact ? 'grid-cols-2 lg:grid-cols-4' : 'grid-cols-1']}>
  {levels.map(level => (
    <div class:list={['rounded-lg border p-3', levelColors[level.label] || 'bg-gray-100 text-gray-800 border-gray-200']}>
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-semibold uppercase tracking-wide">
          {labelDisplay(level.label)}
        </span>
      </div>
      <p class="text-sm">{level.description}</p>
      {!compact && level.example_task && (
        <details class="mt-2">
          <summary class="text-xs font-medium cursor-pointer opacity-75 hover:opacity-100">
            Example task
          </summary>
          <p class="text-xs mt-1 opacity-90">{level.example_task}</p>
          {level.example_response && (
            <p class="text-xs mt-1 italic opacity-75">Model response: {level.example_response}</p>
          )}
        </details>
      )}
    </div>
  ))}
</div>
