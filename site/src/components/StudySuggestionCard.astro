---
interface Props {
  suggestion: {
    name: string;
    type: string;
    description?: string;
    pedagogical_rationale?: string;
    concept_ids: string[];
    template_name?: string;
    cross_curricular: Array<{ target_name: string; hook: string; strength?: string }>;
    period?: string;
    key_figures?: string[];
    disciplinary_concepts?: string[];
    sources?: string[];
    enquiry_question?: string;
    enquiry_type?: string;
    misconceptions?: string[];
    variables?: string;
    writing_outcome?: string;
    genre?: string;
    place?: string;
    contrast?: string;
    cpa_stage?: string;
    manipulatives?: string[];
    representations?: string[];
    fluency_targets?: string[];
    nc_aim_emphasis?: string;
  };
  conceptNames: Map<string, string>;
}

const { suggestion, conceptNames } = Astro.props;

const typeLabels: Record<string, string> = {
  HistoryStudy: 'History Study',
  GeoStudy: 'Geography Study',
  ScienceEnquiry: 'Science Enquiry',
  EnglishUnit: 'English Unit',
  ArtTopicSuggestion: 'Art',
  MusicTopicSuggestion: 'Music',
  DTTopicSuggestion: 'Design & Technology',
  ComputingTopicSuggestion: 'Computing',
  MathsTopicSuggestion: 'Mathematics',
  TopicSuggestion: 'Topic',
};

const typeColors: Record<string, string> = {
  HistoryStudy: 'bg-amber-50 text-amber-700 border-amber-200',
  GeoStudy: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  ScienceEnquiry: 'bg-blue-50 text-blue-700 border-blue-200',
  EnglishUnit: 'bg-rose-50 text-rose-700 border-rose-200',
  ArtTopicSuggestion: 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-200',
  MusicTopicSuggestion: 'bg-violet-50 text-violet-700 border-violet-200',
  DTTopicSuggestion: 'bg-orange-50 text-orange-700 border-orange-200',
  ComputingTopicSuggestion: 'bg-cyan-50 text-cyan-700 border-cyan-200',
  MathsTopicSuggestion: 'bg-purple-50 text-purple-700 border-purple-200',
  TopicSuggestion: 'bg-gray-50 text-gray-700 border-gray-200',
};

const typeLabel = typeLabels[suggestion.type] || suggestion.type;
const colorClass = typeColors[suggestion.type] || typeColors.TopicSuggestion;
---

<div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-sm transition-shadow">
  <div class="flex items-center gap-2 flex-wrap">
    <h3 class="font-medium text-gray-900">{suggestion.name}</h3>
    <span class:list={['text-xs px-2 py-0.5 rounded-full border', colorClass]}>
      {typeLabel}
    </span>
    {suggestion.template_name && (
      <span class="text-xs bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded-full">
        {suggestion.template_name}
      </span>
    )}
  </div>

  {suggestion.description && (
    <p class="text-sm text-gray-600 mt-2">{suggestion.description}</p>
  )}

  {suggestion.pedagogical_rationale && (
    <details class="mt-2">
      <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">
        Pedagogical rationale
      </summary>
      <p class="text-sm text-gray-600 mt-1 pl-4 border-l-2 border-gray-200">
        {suggestion.pedagogical_rationale}
      </p>
    </details>
  )}

  <!-- Subject-specific details -->
  <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-600">
    {suggestion.period && (
      <span><span class="font-medium text-gray-500">Period:</span> {suggestion.period}</span>
    )}
    {suggestion.enquiry_question && (
      <span><span class="font-medium text-gray-500">Enquiry:</span> {suggestion.enquiry_question}</span>
    )}
    {suggestion.enquiry_type && (
      <span><span class="font-medium text-gray-500">Type:</span> {suggestion.enquiry_type}</span>
    )}
    {suggestion.writing_outcome && (
      <span><span class="font-medium text-gray-500">Outcome:</span> {suggestion.writing_outcome}</span>
    )}
    {suggestion.genre && (
      <span><span class="font-medium text-gray-500">Genre:</span> {suggestion.genre}</span>
    )}
    {suggestion.place && (
      <span><span class="font-medium text-gray-500">Place:</span> {suggestion.place}</span>
    )}
    {suggestion.contrast && (
      <span><span class="font-medium text-gray-500">Contrast:</span> {suggestion.contrast}</span>
    )}
    {suggestion.variables && (
      <span><span class="font-medium text-gray-500">Variables:</span> {suggestion.variables}</span>
    )}
  </div>

  <!-- Maths-specific details -->
  {suggestion.cpa_stage && (
    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-600">
      <span><span class="font-medium text-gray-500">CPA Stage:</span> {suggestion.cpa_stage.replace(/_/g, ' → ')}</span>
      {suggestion.nc_aim_emphasis && (
        <span><span class="font-medium text-gray-500">NC Aim:</span> {suggestion.nc_aim_emphasis.replace(/_/g, ' ')}</span>
      )}
    </div>
  )}

  {suggestion.manipulatives && suggestion.manipulatives.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {suggestion.manipulatives.map(m => (
        <span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded">
          {m}
        </span>
      ))}
    </div>
  )}

  {suggestion.representations && suggestion.representations.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {suggestion.representations.map(r => (
        <span class="text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">
          {r}
        </span>
      ))}
    </div>
  )}

  {suggestion.fluency_targets && suggestion.fluency_targets.length > 0 && (
    <div class="mt-2">
      <span class="text-xs font-medium text-gray-500">Fluency targets: </span>
      <span class="text-xs text-gray-600">{suggestion.fluency_targets.join('; ')}</span>
    </div>
  )}

  {suggestion.key_figures && suggestion.key_figures.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {suggestion.key_figures.map(f => (
        <span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded">
          {f}
        </span>
      ))}
    </div>
  )}

  {suggestion.disciplinary_concepts && suggestion.disciplinary_concepts.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {suggestion.disciplinary_concepts.map(dc => (
        <span class="text-xs bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
          {dc}
        </span>
      ))}
    </div>
  )}

  {suggestion.sources && suggestion.sources.length > 0 && (
    <div class="mt-2">
      <span class="text-xs font-medium text-gray-500">Sources: </span>
      <span class="text-xs text-gray-600">{suggestion.sources.join(', ')}</span>
    </div>
  )}

  {suggestion.misconceptions && suggestion.misconceptions.length > 0 && (
    <div class="mt-2">
      <span class="text-xs font-medium text-gray-500">Misconceptions: </span>
      <span class="text-xs text-gray-600">{suggestion.misconceptions.join(', ')}</span>
    </div>
  )}

  <!-- Delivered concepts -->
  {suggestion.concept_ids.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1">
      {suggestion.concept_ids.map(cid => (
        <a
          href={`#${cid}`}
          class="text-xs bg-gray-50 text-gray-600 px-1.5 py-0.5 rounded hover:bg-blue-50 hover:text-blue-700 transition-colors"
        >
          {conceptNames.get(cid) || cid}
        </a>
      ))}
    </div>
  )}

  <!-- Cross-curricular links -->
  {suggestion.cross_curricular.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {suggestion.cross_curricular.map(cc => (
        <span class="text-xs bg-purple-50 text-purple-600 px-2 py-0.5 rounded-full">
          {cc.target_name}{cc.hook ? `: ${cc.hook}` : ''}
        </span>
      ))}
    </div>
  )}
</div>
