---
interface Props {
  mode: string | null | undefined;
  size?: 'sm' | 'md';
}

const { mode, size = 'sm' } = Astro.props;

const modeConfig: Record<string, { bg: string; label: string }> = {
  'DM-AI': { bg: 'bg-emerald-100 text-emerald-800', label: 'AI Direct' },
  'DM-AF': { bg: 'bg-blue-100 text-blue-800', label: 'AI Facilitated' },
  'DM-GM': { bg: 'bg-amber-100 text-amber-800', label: 'Guided Materials' },
  'DM-ST': { bg: 'bg-red-100 text-red-800', label: 'Specialist Teacher' },
};

const config = mode ? modeConfig[mode] : null;
const sizeClass = size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-sm px-3 py-1';
---

{config && (
  <span class:list={['rounded-full font-medium whitespace-nowrap', config.bg, sizeClass]}>
    {config.label}
  </span>
)}
