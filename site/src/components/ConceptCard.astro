---
import DifficultyLevels from './DifficultyLevels.astro';
import DeliveryBadge from './DeliveryBadge.astro';

interface Props {
  concept: {
    concept_id: string;
    name: string;
    description?: string;
    concept_type?: string;
    teaching_weight?: number;
    is_keystone?: boolean;
    teaching_guidance?: string;
    key_vocabulary?: string;
    common_misconceptions?: string;
    difficulty_levels?: any[];
    representation_stages?: any[];
    vocabulary_terms?: Array<{
      term_id: string;
      term: string;
      definition?: string;
      tier?: number;
      word_class?: string;
      introduced?: boolean;
      importance?: string;
    }>;
    delivery_mode?: {
      mode_id: string;
      name: string;
      confidence?: string;
      rationale?: string;
    };
  };
  expanded?: boolean;
}

const { concept, expanded = false } = Astro.props;

const typeColors: Record<string, string> = {
  knowledge: 'bg-blue-50 text-blue-700',
  skill: 'bg-teal-50 text-teal-700',
  understanding: 'bg-purple-50 text-purple-700',
  application: 'bg-amber-50 text-amber-700',
};

const weightDots = concept.teaching_weight || 0;

const stageColors: Record<string, string> = {
  concrete: 'bg-orange-100 text-orange-800 border-orange-200',
  pictorial: 'bg-cyan-100 text-cyan-800 border-cyan-200',
  abstract: 'bg-violet-100 text-violet-800 border-violet-200',
};
---

<div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-sm transition-shadow" id={concept.concept_id}>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-semibold text-gray-900">{concept.name}</h3>
        {concept.is_keystone && (
          <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full font-medium">
            Keystone
          </span>
        )}
        {concept.concept_type && (
          <span class:list={['text-xs px-2 py-0.5 rounded-full', typeColors[concept.concept_type] || 'bg-gray-100 text-gray-700']}>
            {concept.concept_type}
          </span>
        )}
        <DeliveryBadge mode={concept.delivery_mode?.mode_id} />
      </div>
      <p class="text-xs text-gray-400 mt-0.5 font-mono">{concept.concept_id}</p>
    </div>
    {weightDots > 0 && (
      <div class="flex items-center gap-0.5 shrink-0" title={`Teaching weight: ${weightDots}/6`}>
        {Array.from({ length: 6 }).map((_, i) => (
          <div class:list={['w-1.5 h-1.5 rounded-full', i < weightDots ? 'bg-blue-500' : 'bg-gray-200']} />
        ))}
      </div>
    )}
  </div>

  {concept.description && (
    <p class="text-sm text-gray-600 mt-2">{concept.description}</p>
  )}

  {concept.teaching_guidance && (
    <details class="mt-3">
      <summary class="text-sm font-medium text-gray-700 cursor-pointer hover:text-gray-900">
        Teaching guidance
      </summary>
      <p class="text-sm text-gray-600 mt-1 pl-4 border-l-2 border-gray-200">
        {concept.teaching_guidance}
      </p>
    </details>
  )}

  {concept.vocabulary_terms && concept.vocabulary_terms.length > 0 ? (
    <details class="mt-2">
      <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">
        Vocabulary ({concept.vocabulary_terms.length} terms)
      </summary>
      <div class="mt-1 space-y-1 pl-4 border-l-2 border-sky-200">
        {concept.vocabulary_terms.map((v: any) => (
          <div class="text-xs">
            <span class="font-semibold text-gray-700">{v.term}</span>
            {v.tier === 3 && <span class="text-sky-500 ml-1" title="Domain-specific vocabulary (Tier 3)">T3</span>}
            {v.introduced && <span class="text-green-500 ml-1" title="Introduced in this concept">new</span>}
            {v.definition && <span class="text-gray-600 ml-1">— {v.definition}</span>}
          </div>
        ))}
      </div>
    </details>
  ) : concept.key_vocabulary && (
    <div class="mt-2">
      <span class="text-xs font-medium text-gray-500">Vocabulary:</span>
      <span class="text-xs text-gray-600 ml-1">{concept.key_vocabulary}</span>
    </div>
  )}

  {concept.common_misconceptions && (
    <details class="mt-2">
      <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">
        Common misconceptions
      </summary>
      <p class="text-xs text-gray-600 mt-1 pl-4 border-l-2 border-amber-200">
        {concept.common_misconceptions}
      </p>
    </details>
  )}

  {concept.difficulty_levels && concept.difficulty_levels.length > 0 && (
    <div class="mt-3">
      <p class="text-xs font-medium text-gray-500 mb-2">Difficulty levels</p>
      <DifficultyLevels levels={concept.difficulty_levels} compact={!expanded} />
    </div>
  )}

  {concept.representation_stages && concept.representation_stages.length > 0 && (
    <div class="mt-3">
      <p class="text-xs font-medium text-gray-500 mb-2">CPA Stages</p>
      <div class="flex gap-2">
        {concept.representation_stages.map((rs: any) => (
          <div class:list={['flex-1 rounded-lg border p-2', stageColors[rs.stage] || 'bg-gray-100 border-gray-200']}>
            <p class="text-xs font-semibold capitalize">{rs.stage}</p>
            <p class="text-xs mt-0.5">{rs.description}</p>
            {rs.transition_cue && (
              <p class="text-xs mt-1 italic opacity-75">Transition: {rs.transition_cue}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  {concept.delivery_mode?.rationale && (
    <details class="mt-2">
      <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">
        Delivery rationale
      </summary>
      <p class="text-xs text-gray-600 mt-1">{concept.delivery_mode.rationale}</p>
    </details>
  )}
</div>
