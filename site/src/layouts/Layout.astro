---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Explore the UK National Curriculum as an interactive knowledge graph' } = Astro.props;

const buildId = process.env.GITHUB_SHA?.substring(0, 7) || 'dev';
const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | UK Curriculum Explorer</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-4 md:gap-8 min-w-0">
            <a href={`${base}/`} class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors whitespace-nowrap shrink-0">
              <span class="hidden sm:inline">UK Curriculum Explorer</span>
              <span class="sm:hidden">Curriculum</span>
            </a>
            <div class="hidden md:flex items-center gap-6">
              <a href={`${base}/planners`} class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Planners</a>
              <a href={`${base}/years`} class="text-sm text-gray-600 hover:text-gray-900 transition-colors">By Year</a>
              <a href={`${base}/#subjects`} class="text-sm text-gray-600 hover:text-gray-900 transition-colors">By Subject</a>
              <a href={`${base}/guide`} class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Guide</a>
              <!-- Data dropdown -->
              <div class="relative group">
                <button class="text-sm text-gray-600 hover:text-gray-900 transition-colors flex items-center gap-1" id="data-dropdown-btn">
                  Data
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div id="data-dropdown" class="absolute left-0 top-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg hidden w-48 py-1 z-50">
                  <a href={`${base}/delivery`} class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900">Delivery Readiness</a>
                  <a href={`${base}/lenses`} class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900">Thinking Lenses</a>
                  <a href={`${base}/profiles`} class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900">Learner Profiles</a>
                </div>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-2 md:gap-4">
            <div id="search-container" class="relative hidden sm:block">
              <input
                type="text"
                id="search-input"
                placeholder="Search concepts, planners..."
                class="w-48 md:w-64 pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
              />
              <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <div id="search-results" class="absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-96 overflow-y-auto z-50"></div>
            </div>
            <!-- Mobile search button -->
            <button id="mobile-search-btn" class="sm:hidden p-2 text-gray-600 hover:text-gray-900">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <!-- Mobile menu button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-gray-900">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
        <!-- Mobile search (expandable) -->
        <div id="mobile-search" class="sm:hidden hidden pb-3">
          <div id="mobile-search-container" class="relative">
            <input
              type="text"
              id="mobile-search-input"
              placeholder="Search concepts, planners..."
              class="w-full pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
            />
            <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <div id="mobile-search-results" class="absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg hidden max-h-96 overflow-y-auto z-50"></div>
          </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="md:hidden hidden pb-4">
          <a href={`${base}/planners`} class="block px-1 py-2.5 text-sm font-medium text-gray-700 hover:text-blue-600">Planners</a>
          <a href={`${base}/years`} class="block px-1 py-2.5 text-sm font-medium text-gray-700 hover:text-blue-600">By Year</a>
          <a href={`${base}/#subjects`} class="block px-1 py-2.5 text-sm font-medium text-gray-700 hover:text-blue-600">By Subject</a>
          <a href={`${base}/guide`} class="block px-1 py-2.5 text-sm font-medium text-gray-700 hover:text-blue-600">Guide</a>
          <div class="border-t border-gray-100 mt-2 pt-2">
            <p class="text-xs text-gray-400 uppercase tracking-wider mb-1 px-1">Data</p>
            <a href={`${base}/delivery`} class="block px-1 py-2.5 text-sm text-gray-600 hover:text-blue-600">Delivery Readiness</a>
            <a href={`${base}/lenses`} class="block px-1 py-2.5 text-sm text-gray-600 hover:text-blue-600">Thinking Lenses</a>
            <a href={`${base}/profiles`} class="block px-1 py-2.5 text-sm text-gray-600 hover:text-blue-600">Learner Profiles</a>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <p class="text-sm text-gray-500 text-center">
          UK National Curriculum Knowledge Graph &middot;
          Data compiled from the <a href="https://www.gov.uk/government/collections/national-curriculum" class="text-blue-600 hover:underline">UK National Curriculum (2014)</a>
        </p>
        <p class="text-xs text-gray-400 text-center mt-1">
          Build: {buildId} &middot; {buildTime}
        </p>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Mobile search toggle
      const mobileSearchBtn = document.getElementById('mobile-search-btn');
      const mobileSearchPanel = document.getElementById('mobile-search');
      const mobileSearchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
      mobileSearchBtn?.addEventListener('click', () => {
        mobileSearchPanel?.classList.toggle('hidden');
        if (!mobileSearchPanel?.classList.contains('hidden')) {
          mobileSearchInput?.focus();
        }
      });

      // Data dropdown toggle
      const dropdownBtn = document.getElementById('data-dropdown-btn');
      const dropdown = document.getElementById('data-dropdown');
      dropdownBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        dropdown?.classList.toggle('hidden');
      });
      document.addEventListener('click', (e) => {
        if (!dropdownBtn?.contains(e.target as Node) && !dropdown?.contains(e.target as Node)) {
          dropdown?.classList.add('hidden');
        }
      });

      // Client-side search
      const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
      let searchIndex: any[] | null = null;
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const searchResults = document.getElementById('search-results');

      async function loadSearchIndex() {
        if (searchIndex) return searchIndex;
        const res = await fetch(`${BASE}/search.json`);
        searchIndex = await res.json();
        return searchIndex;
      }

      function renderResults(results: any[], target?: HTMLElement | null) {
        const container = target || searchResults;
        if (!container) return;
        if (results.length === 0) {
          container.innerHTML = '<div class="p-3 text-sm text-gray-500">No results found</div>';
          container.classList.remove('hidden');
          return;
        }
        const typeIcons: Record<string, string> = {
          concept: '<span class="text-xs bg-teal-50 text-teal-700 px-1.5 py-0.5 rounded">Concept</span>',
          domain: '<span class="text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">Domain</span>',
          planner: '<span class="text-xs bg-violet-50 text-violet-700 px-1.5 py-0.5 rounded">Planner</span>',
          study: '<span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded">Study</span>',
        };
        const html = results.slice(0, 20).map((r: any) => {
          let href: string;
          if (r.type === 'planner') {
            href = `${BASE}/planners/${r.folder}/${r.slug}`;
          } else if (r.type === 'domain' || r.type === 'study') {
            href = `${BASE}/domains/${r.domain_id || r.id}`;
          } else {
            href = `${BASE}/domains/${r.domain_id}#${r.id}`;
          }
          return `<a href="${href}" class="block p-3 hover:bg-gray-50 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-2">
              ${typeIcons[r.type] || ''}
              <span class="text-sm font-medium text-gray-900">${r.name}</span>
            </div>
            <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-500">
              ${r.subject ? `<span>${r.subject}</span>` : ''}
              ${r.year_id ? `<span>${r.year_id}</span>` : ''}
              ${r.key_stage ? `<span>${r.key_stage}</span>` : ''}
            </div>
          </a>`;
        }).join('');
        container.innerHTML = html;
        container.classList.remove('hidden');
      }

      let debounceTimer: ReturnType<typeof setTimeout>;
      searchInput?.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
        if (query.length < 2) {
          searchResults?.classList.add('hidden');
          return;
        }
        debounceTimer = setTimeout(async () => {
          const index = await loadSearchIndex();
          if (!index) return;
          const terms = query.split(/\s+/);
          const scored = index
            .map((item: any) => {
              const name = (item.name || '').toLowerCase();
              const text = `${name} ${item.description || ''} ${item.subject || ''} ${item.year_id || ''}`.toLowerCase();
              if (!terms.every((t: string) => text.includes(t))) return null;
              let score = 0;
              // Planners rank highest — teachers search for these
              if (item.type === 'planner') score += 100;
              else if (item.type === 'domain') score += 50;
              else if (item.type === 'study') score += 40;
              // Name match >> description match
              if (terms.every((t: string) => name.includes(t))) score += 80;
              else if (terms.some((t: string) => name.includes(t))) score += 30;
              return { item, score };
            })
            .filter(Boolean)
            .sort((a: any, b: any) => b.score - a.score)
            .slice(0, 20)
            .map((r: any) => r.item);
          renderResults(scored);
        }, 150);
      });

      // Mobile search input
      const mobileSearchResults = document.getElementById('mobile-search-results');
      let mobileDebounceTimer: ReturnType<typeof setTimeout>;
      mobileSearchInput?.addEventListener('input', (e) => {
        clearTimeout(mobileDebounceTimer);
        const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
        if (query.length < 2) {
          mobileSearchResults?.classList.add('hidden');
          return;
        }
        mobileDebounceTimer = setTimeout(async () => {
          const index = await loadSearchIndex();
          if (!index) return;
          const terms = query.split(/\s+/);
          const scored = index
            .map((item: any) => {
              const name = (item.name || '').toLowerCase();
              const text = `${name} ${item.description || ''} ${item.subject || ''} ${item.year_id || ''}`.toLowerCase();
              if (!terms.every((t: string) => text.includes(t))) return null;
              let score = 0;
              if (item.type === 'planner') score += 100;
              else if (item.type === 'domain') score += 50;
              else if (item.type === 'study') score += 40;
              if (terms.every((t: string) => name.includes(t))) score += 80;
              else if (terms.some((t: string) => name.includes(t))) score += 30;
              return { item, score };
            })
            .filter(Boolean)
            .sort((a: any, b: any) => b.score - a.score)
            .slice(0, 20)
            .map((r: any) => r.item);
          renderResults(scored, mobileSearchResults);
        }, 150);
      });

      // Close search on click outside
      document.addEventListener('click', (e) => {
        if (!document.getElementById('search-container')?.contains(e.target as Node)) {
          searchResults?.classList.add('hidden');
        }
        if (!document.getElementById('mobile-search-container')?.contains(e.target as Node)) {
          mobileSearchResults?.classList.add('hidden');
        }
      });

      // Close search on Escape
      searchInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          searchResults?.classList.add('hidden');
          searchInput.blur();
        }
      });
      mobileSearchInput?.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          mobileSearchResults?.classList.add('hidden');
          mobileSearchInput.blur();
        }
      });
    </script>
  </body>
</html>
