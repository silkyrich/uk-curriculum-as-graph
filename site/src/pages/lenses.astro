---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getThinkingLenses } from '../lib/data';

const lenses = getThinkingLenses();
const totalClusters = lenses.reduce((sum, l) => sum + l.cluster_count, 0);
---

<Layout title="Thinking Lenses" description="10 cross-subject cognitive lenses for framing learning across the curriculum.">
  <Breadcrumb items={[
    { label: 'Dashboard', href: '/' },
    { label: 'Thinking Lenses' },
  ]} />

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Thinking Lenses</h1>
    <p class="text-lg text-gray-600 mt-2 max-w-3xl">
      10 cross-subject cognitive lenses adapted from NGSS Crosscutting Concepts and
      UK-specific frameworks. Each lens provides a way to frame learning that
      transfers across subjects.
    </p>
    <p class="text-sm text-gray-500 mt-2">
      {lenses.length} lenses applied across {totalClusters} cluster assignments
    </p>
  </div>

  <!-- Lens cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
    {lenses.map(lens => (
      <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-sm transition-shadow" id={lens.id}>
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold" style={`color: ${lens.color || '#7C3AED'}`}>
              {lens.name}
            </h2>
            <p class="text-sm text-gray-600 mt-1">{lens.description}</p>
          </div>
          <div class="text-right shrink-0">
            <p class="text-2xl font-bold text-gray-900">{lens.primary_count}</p>
            <p class="text-xs text-gray-500">primary uses</p>
          </div>
        </div>

        <div class="mt-4 p-3 bg-violet-50 border border-violet-200 rounded-lg">
          <p class="text-sm font-medium text-violet-900">Key question</p>
          <p class="text-sm text-violet-700 italic mt-0.5">{lens.key_question}</p>
        </div>

        {lens.agent_prompt && (
          <details class="mt-3">
            <summary class="text-sm font-medium text-gray-700 cursor-pointer hover:text-gray-900">
              Agent prompt
            </summary>
            <p class="text-sm text-gray-600 mt-1 p-3 bg-gray-50 rounded-lg font-mono text-xs">
              {lens.agent_prompt}
            </p>
          </details>
        )}

        <!-- Age-banded prompts -->
        {lens.ks_prompts && lens.ks_prompts.length > 0 && (
          <details class="mt-3">
            <summary class="text-sm font-medium text-gray-700 cursor-pointer hover:text-gray-900">
              Age-banded prompts ({lens.ks_prompts.length} key stages)
            </summary>
            <div class="mt-2 space-y-2">
              {lens.ks_prompts
                .sort((a, b) => (a.key_stage || '').localeCompare(b.key_stage || ''))
                .map(ksp => (
                  <div class="p-3 bg-gray-50 rounded-lg">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">
                      {ksp.key_stage}
                    </p>
                    <p class="text-xs text-gray-700">{ksp.agent_prompt}</p>
                    {ksp.question_stems && ksp.question_stems.length > 0 && (
                      <div class="mt-2">
                        <p class="text-xs font-medium text-gray-500">Question stems:</p>
                        <ul class="list-disc list-inside text-xs text-gray-600 mt-1">
                          {ksp.question_stems.map(qs => <li>{qs}</li>)}
                        </ul>
                      </div>
                    )}
                  </div>
                ))
              }
            </div>
          </details>
        )}

        <div class="mt-3 flex items-center gap-4 text-xs text-gray-500">
          <span>{lens.cluster_count} total cluster assignments</span>
          <span>{lens.primary_count} as primary lens</span>
        </div>
      </div>
    ))}
  </div>
</Layout>
